#!/usr/bin/env -S uv run --script
# /// script
# dependencies = ["rich"]
# ///
# netty — render vnStat traffic stats as a clean, aligned bar-chart table.
# Parses vnStat's textual output (no JSON, no jq). No estimates shown.
#
# Usage: netty [-i iface] [-w [N]] [-d|-m]
#   -i iface   select interface (default: first in database)
#   -w [N]     weekly view: a week of per-day rows. N=1 (default) = most recent
#              7 days, N=2 = the week before, etc.
#   -d         daily only (today)  [default]
#   -m         monthly only
#   (default shows the Daily section only)
import re
import subprocess
import sys
from datetime import datetime, date, timedelta

from rich.console import Console
from rich.panel import Panel
from rich.table import Table

UNIT = {
    "B": 1,
    "KiB": 1024,
    "MiB": 1024**2,
    "GiB": 1024**3,
    "TiB": 1024**4,
    "PiB": 1024**5,
}
VALUE_RE = re.compile(r"(\d+(?:\.\d+)?)\s*(B|KiB|MiB|GiB|TiB|PiB)")
DATE_RE = re.compile(r"^\s*(\d{4}-\d{2}(?:-\d{2})?)\b")
BAR_W = 20
console = Console()


def run(args):
    return subprocess.run(["vnstat", *args], capture_output=True, text=True).stdout


def human(b):
    units = ["B", "KiB", "MiB", "GiB", "TiB", "PiB"]
    i = 0
    while b >= 1024 and i < len(units) - 1:
        b /= 1024
        i += 1
    if b >= 100:
        return f"{b:.0f} {units[i]}"
    if b >= 10:
        return f"{b:.1f} {units[i]}"
    return f"{b:.2f} {units[i]}"


def parse_rows(text):
    rows = []
    for line in text.splitlines():
        dm = DATE_RE.match(line)
        if not dm:
            continue
        vals = [(float(v), UNIT[u]) for v, u in VALUE_RE.findall(line)]
        if len(vals) >= 3:
            rx, tx, tot = (x * m for x, m in vals[:3])
            rows.append((dm.group(1), rx, tx, tot))
    return rows


def parse_summary(text):
    for line in text.splitlines():
        if re.search(r"\btotal:", line, re.I):
            vals = [(float(v), UNIT[u]) for v, u in VALUE_RE.findall(line)]
            if len(vals) >= 3:
                return [x * m for x, m in vals[:3]]
    return [0, 0, 0]


def meta(text, iface):
    name = iface
    if not name:
        for line in text.splitlines():
            if "since" in line.lower():
                name = line.split()[0].rstrip(":/")
                break
        if not name:
            for line in text.splitlines():
                line = line.strip()
                if line:
                    name = line.split()[0].rstrip(":/")
                    break
    since = ""
    m = re.search(r"since\s+(\S+)", text)
    if m:
        since = m.group(1)
    return name, since


def bar(value, maximum, style):
    n = 0 if maximum <= 0 else round(value / maximum * BAR_W)
    n = max(0, min(n, BAR_W))
    return "█" * n + " " * (BAR_W - n)


def render_section(title, rows):
    if not rows:
        console.print(f"[dim]{title}: no data[/dim]\n")
        return
    maxr = max(r[1] for r in rows) or 1
    maxt = max(r[2] for r in rows) or 1
    t = Table(title=title, header_style="bold cyan", expand=False)
    t.add_column("Date", style="dim")
    t.add_column("↓ download", style="green")
    t.add_column("↑ upload", style="yellow")
    t.add_column("Total", style="white", justify="right")
    for date, rx, tx, tot in rows:
        t.add_row(date, bar(rx, maxr, "green"), bar(tx, maxt, "yellow"), human(tot))
    console.print(t, "\n")


def main():
    iface = ""
    week = 0
    wnum = 1
    show_daily = 1
    show_monthly = 0
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        a = args[i]
        if a == "-i":
            iface = args[i + 1]
            i += 2
        elif a == "-w":
            week = 1
            if i + 1 < len(args) and re.fullmatch(r"\d+", args[i + 1]):
                wnum = int(args[i + 1])
                i += 1
            i += 1
        elif a == "-m":
            show_daily = 0
            show_monthly = 1
            i += 1
        elif a == "-d":
            show_daily = 1
            show_monthly = 0
            i += 1
        elif a in ("-h", "--help"):
            print(__doc__)
            return
        else:
            print(f"unknown arg: {a}", file=sys.stderr)
            sys.exit(1)

    iface_args = ["-i", iface] if iface else []
    summary = run(iface_args)
    name, since = meta(summary, iface)
    trx, ttx, ttot = parse_summary(summary)

    console.print(
        Panel(
            f"vnStat · {name} · since {since}\n"
            f"total  [green]↓ {human(trx)}[/green]   [yellow]↑ {human(ttx)}[/yellow]   = {human(ttot)}",
            border_style="cyan",
        )
    )

    days = parse_rows(run(["-d", *iface_args]))
    months = parse_rows(run(["-m", *iface_args]))
    n = len(days)

    if week:
        dates = [datetime.strptime(d[0], "%Y-%m-%d").date() for d in days]
        anchor = max(dates) if dates else date.today()
        end = anchor - timedelta(days=7 * (wnum - 1))
        start = end - timedelta(days=6)
        by_date = {d[0]: d for d in days}
        window = []
        d = start
        while d <= end:
            key = d.strftime("%Y-%m-%d")
            window.append(by_date.get(key, (key, 0, 0, 0)))
            d += timedelta(days=1)
        render_section(
            f"Week {wnum} · {window[0][0]} – {window[-1][0]} · {human(sum(r[3] for r in window))}",
            list(reversed(window)),
        )
    else:
        if show_daily:
            today = days[-1:] if n else []
            render_section("Daily", list(reversed(today)))
        if show_monthly:
            render_section("Monthly", list(reversed(months)))


if __name__ == "__main__":
    main()
